# Rust / Soroban
target/
**/target/
Cargo.lock.orig

# Soroban test snapshots (regenerated by `cargo test`)
**/test_snapshots/

# RISC Zero
**/*.bin
methods/guest/target/

# Generated prover artifacts — working dir ignored, but the canonical demo proof
# (the one matching the live on-chain attestation) is tracked so verifier-cli and
# scripts/demo.sh work without re-running the ~16GB Groth16 prove.
out/*
!out/proof.json
!out/inclusion/
out/inclusion/*
!out/inclusion/*.json

# Secrets / keys — never commit
.env
.env.*
*.key
*.pem
secret*.txt
*-secret.json
identity.toml

# Node / frontend
node_modules/
dist/
.next/
*.local

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
